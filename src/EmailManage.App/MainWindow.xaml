<Window x:Class="EmailManage.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:EmailManage.ViewModels"
        mc:Ignorable="d"
        Title="{Binding AppTitle}"
        Height="900" Width="860" MinHeight="600" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        Closed="Window_Closed">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header bar -->
            <RowDefinition Height="*"/>      <!-- Content -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER BAR ═══ -->
        <Border Grid.Row="0" Padding="24,14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Color="{StaticResource HeaderGradientStartColor}" Offset="0"/>
                    <GradientStop Color="{StaticResource HeaderGradientEndColor}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="✨" FontSize="24" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="MailZen" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding AppVersion, StringFormat=' (v{0})'}" FontSize="12" Foreground="#EDE9FE"
                               VerticalAlignment="Center" Margin="6,3,0,0" FontWeight="SemiBold"/>
                    <TextBlock Text="Smart Email Cleanup" FontSize="12" Foreground="#D1C4E9" VerticalAlignment="Center" Margin="14,3,0,0"
                               FontStyle="Italic" Opacity="0.85"/>
                </StackPanel>

                <!-- Connection Status Pill -->
                <Border Grid.Column="2" CornerRadius="14" Padding="12,5" VerticalAlignment="Center" Margin="0,0,12,0"
                        Background="{Binding ConnectionStatusColor, Converter={StaticResource StringToColorBrushConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Margin="0,0,6,0" VerticalAlignment="Center" Fill="White"/>
                        <TextBlock Text="{Binding ConnectionStatus}" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Gear Icon (Settings) -->
                <Button Grid.Column="3" Content="⚙️" FontSize="20" Background="Transparent" BorderThickness="0"
                        Foreground="White" Cursor="Hand" Padding="8,4" ToolTip="Settings"
                        Command="{Binding ToggleSettingsCommand}"/>
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Border Grid.Row="1" Visibility="{Binding ShowSettings, Converter={StaticResource BoolToVis}}"
                Background="#66F8FAFC" Panel.ZIndex="20" Margin="0,8,0,0">
            <Border Background="White" CornerRadius="12" Padding="28" Margin="40,28,40,24"
                    BorderBrush="#E5E7EB" BorderThickness="1" VerticalAlignment="Top">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.12" Color="Black"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="760">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="⚙️ Settings" FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Button Content="✕" FontSize="16" Background="Transparent" BorderThickness="0"
                                    Foreground="{StaticResource TextSecondaryBrush}" Cursor="Hand" Margin="20,0,0,0"
                                    Command="{Binding ToggleSettingsCommand}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="🤖 AI Engine (Ollama)" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border CornerRadius="4" Padding="8,4" Margin="0,0,8,0"
                                    Background="{Binding AiStatusColor, Converter={StaticResource StringToColorBrushConverter}}">
                                <TextBlock Text="{Binding AiStatus}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="{Binding AiModelName}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AiModelSize, StringFormat=' ({0})'}" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                       Visibility="{Binding AiModelSize, Converter={StaticResource NullToCollapsedConverter}}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding AiOllamaVersion, StringFormat='Ollama v{0}'}" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                                   Visibility="{Binding AiOllamaVersion, Converter={StaticResource NullToCollapsedConverter}}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Button Content="🔄 Check for Updates" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding CheckAiUpdatesCommand}" Margin="0,0,10,0"
                                    Visibility="{Binding IsAiReady, Converter={StaticResource BoolToVis}}"/>
                            <Button Content="📥 Install Ollama + Model" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding InstallOllamaCommand}" Margin="0,0,10,0"
                                    Visibility="{Binding IsAiReady, Converter={StaticResource InverseBoolToVisConverter}}"
                                    IsEnabled="{Binding IsInstallingOllama, Converter={StaticResource InverseBoolConverter}}"/>
                        </StackPanel>

                        <Border Height="1" Background="#E5E7EB" Margin="0,0,0,16"/>

                        <TextBlock Text="📬 Connected Accounts" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding Accounts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="📬" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding EmailAddress}" FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding ProviderHint, StringFormat=' ({0})'}" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Height="1" Background="#E5E7EB" Margin="0,16,0,16"/>

                        <TextBlock Text="🧠 Learned Profile" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding LearnedDomainCount}" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Domains" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding ProtectedSenderCount}" FontSize="20" FontWeight="Bold"
                                           Foreground="#2E7D32" HorizontalAlignment="Center"/>
                                <TextBlock Text="Protected" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{Binding RuledSenderCount}" FontSize="20" FontWeight="Bold"
                                           Foreground="#E65100" HorizontalAlignment="Center"/>
                                <TextBlock Text="Rules" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="{Binding ProfileLastLearnedAt, TargetNullValue='Never'}" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                                <TextBlock Text="Last Learned" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        <Button Content="🗑 Reset Profile" Style="{StaticResource SecondaryButton}"
                                Command="{Binding ResetProfileCommand}" HorizontalAlignment="Left"
                                ToolTip="Clears learned patterns for the selected Inbox Review account."/>

                        <Border Height="1" Background="#E5E7EB" Margin="0,16,0,16"/>

                        <TextBlock Text="🔍 Diagnostics" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Rolling logs (14 days) stored in %LOCALAPPDATA%\EmailManage\" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <Button Content="📂 Open Log Folder" Style="{StaticResource SecondaryButton}"
                                Command="{Binding ExportLogsCommand}" HorizontalAlignment="Left"/>

                        <Border Height="1" Background="#E5E7EB" Margin="0,16,0,16"/>

                        <TextBlock Text="📦 Output Folder" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="MailZen saves Inbox Review CSV/XLSX outputs here." TextWrapping="Wrap"
                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,0,0,10">
                            <TextBlock Text="{Binding DatasetOutputDirectory}" FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                        </Border>
                        <Button Content="📁 Browse Output Folder" Style="{StaticResource SecondaryButton}"
                                Command="{Binding BrowseDatasetOutputDirectoryCommand}" HorizontalAlignment="Left"/>

                        <Border Height="1" Background="#E5E7EB" Margin="0,16,0,16"/>

                        <TextBlock Text="🗂 Clear MailZen Categories — Inbox" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Removes MailZen: Keep / Review / Delete tags from all Inbox emails in the selected accounts."
                                   TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding InboxCleanupAccounts}" Margin="0,0,0,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsChecked}" Margin="0,3">
                                        <TextBlock Text="{Binding Name}" FontSize="12"/>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <CheckBox Content="Also remove MailZen view formatting rules (color stripes)"
                                  IsChecked="{Binding ClearInboxAlsoRemoveFormatting}" FontSize="12" Margin="0,0,0,12"/>
                        <Button Content="🗑 Clear MailZen Categories from Inbox" Style="{StaticResource SecondaryButton}"
                                Command="{Binding ClearInboxCategoriesCommand}" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding ClearInboxCategoriesResult}" FontSize="12" Margin="0,8,0,0"
                                   Foreground="#2E7D32" TextWrapping="Wrap"
                                   Visibility="{Binding ClearInboxCategoriesResult, Converter={StaticResource NullToCollapsedConverter}}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>
        <TabControl Grid.Row="1" BorderThickness="0" Background="Transparent" Margin="0,8,0,0"
                SelectedIndex="{Binding SelectedMainTabIndex}">
            <TabItem Header="Cleanup Wizard" FontSize="16" FontWeight="SemiBold" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
            <Grid Margin="40,28,40,16">

                <!-- ═══ SETTINGS OVERLAY (shown when gear is clicked) ═══ -->
                <Border Visibility="{Binding ShowSettings, Converter={StaticResource BoolToVis}}"
                        Background="White" CornerRadius="12" Padding="28" Margin="0,0,0,16"
                        BorderBrush="#E5E7EB" BorderThickness="1" Panel.ZIndex="10">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.08" Color="Black"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="⚙️ Settings" FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Button Content="✕" FontSize="16" Background="Transparent" BorderThickness="0"
                                    Foreground="{StaticResource TextSecondaryBrush}" Cursor="Hand" Margin="20,0,0,0"
                                    Command="{Binding ToggleSettingsCommand}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TabControl BorderThickness="0" Background="Transparent">
                            <!-- ═══ TAB 1: General Settings ═══ -->
                            <TabItem Header="⚙ General" FontSize="13">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="0,12,0,0">

                        <!-- ═══ AI Model Section ═══ -->
                        <TextBlock Text="🤖 AI Engine (Ollama)" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border CornerRadius="4" Padding="8,4" Margin="0,0,8,0"
                                    Background="{Binding AiStatusColor, Converter={StaticResource StringToColorBrushConverter}}">
                                <TextBlock Text="{Binding AiStatus}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="{Binding AiModelName}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AiModelSize, StringFormat=' ({0})'}" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                       Visibility="{Binding AiModelSize, Converter={StaticResource NullToCollapsedConverter}}"/>
                        </StackPanel>

                        <TextBlock Text="{Binding AiOllamaVersion, StringFormat='Ollama v{0}'}" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                                   Visibility="{Binding AiOllamaVersion, Converter={StaticResource NullToCollapsedConverter}}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Button Content="🔄 Check for Updates" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding CheckAiUpdatesCommand}" Margin="0,0,10,0"
                                    Visibility="{Binding IsAiReady, Converter={StaticResource BoolToVis}}"/>
                            <!-- Install Ollama button (shown only when not installed) -->
                            <Button Content="📥 Install Ollama + Model" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding InstallOllamaCommand}" Margin="0,0,10,0"
                                    Visibility="{Binding IsAiReady, Converter={StaticResource InverseBoolToVisConverter}}"
                                    IsEnabled="{Binding IsInstallingOllama, Converter={StaticResource InverseBoolConverter}}"/>
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding IsInstallingOllama, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="⏳" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                           MaxWidth="300" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Separator -->
                        <Border Height="1" Background="#E5E7EB" Margin="0,0,0,16"/>

                        <!-- ═══ Connected Accounts ═══ -->
                        <TextBlock Text="📬 Connected Accounts" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding Accounts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="📬" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding EmailAddress}" FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding ProviderHint, StringFormat=' ({0})'}" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Separator -->
                        <Border Height="1" Background="#E5E7EB" Margin="0,16,0,16"/>

                        <!-- ═══ Learned Profile Stats ═══ -->
                        <TextBlock Text="🧠 Learned Profile" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding LearnedDomainCount}" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Domains" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding ProtectedSenderCount}" FontSize="20" FontWeight="Bold"
                                           Foreground="#2E7D32" HorizontalAlignment="Center"/>
                                <TextBlock Text="Protected" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{Binding RuledSenderCount}" FontSize="20" FontWeight="Bold"
                                           Foreground="#E65100" HorizontalAlignment="Center"/>
                                <TextBlock Text="Rules" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="{Binding ProfileLastLearnedAt, TargetNullValue='Never'}" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                                <TextBlock Text="Last Learned" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Button Content="🗑 Reset Profile" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding ResetProfileCommand}" Margin="0,0,10,0"
                                    ToolTip="Clears all learned patterns, protected senders, and rule tracking. Does NOT delete Outlook rules."/>
                        </StackPanel>

                        <!-- Separator -->
                        <Border Height="1" Background="#E5E7EB" Margin="0,0,0,16"/>

                        <!-- ═══ Diagnostics ═══ -->
                        <TextBlock Text="🔍 Diagnostics" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Rolling logs (14 days) stored in %LOCALAPPDATA%\EmailManage\" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <Button Content="📂 Open Log Folder" Style="{StaticResource SecondaryButton}"
                                Command="{Binding ExportLogsCommand}" HorizontalAlignment="Left"
                                ToolTip="Opens the log folder in File Explorer for sharing or review."/>

                        <!-- Separator -->
                        <Border Height="1" Background="#E5E7EB" Margin="0,16,0,16"/>

                        <!-- ═══ Dataset Output Folder ═══ -->
                        <TextBlock Text="📦 Dataset Output Folder" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Choose where exported dataset CSV/XLSX files are saved. This applies to both new exports and re-scored datasets."
                               TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,0,0,10">
                            <TextBlock Text="{Binding DatasetOutputDirectory}" FontSize="12"
                                   Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                        </Border>
                        <Button Content="📁 Browse Output Folder" Style="{StaticResource SecondaryButton}"
                            Command="{Binding BrowseDatasetOutputDirectoryCommand}" HorizontalAlignment="Left"
                            ToolTip="Select the folder where MailZen saves dataset export files."/>

                        <!-- Separator -->
                        <Border Height="1" Background="#E5E7EB" Margin="0,16,0,16"/>

                        <!-- ═══ Clear MailZen Categories ═══ -->
                        <TextBlock Text="🗂 Clear MailZen Categories — Inbox" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Removes MailZen: Keep / Review / Delete tags from ALL emails in each selected account's Inbox. Does not move or delete anything."
                                   TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                        <TextBlock Text="Apply to accounts:" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <ItemsControl ItemsSource="{Binding InboxCleanupAccounts}" Margin="0,0,0,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsChecked}" Margin="0,3">
                                        <TextBlock Text="{Binding Name}" FontSize="12"/>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <CheckBox Content="Also remove MailZen view formatting rules (color stripes)"
                                  IsChecked="{Binding ClearInboxAlsoRemoveFormatting}"
                                  FontSize="12" Margin="0,0,0,12"/>

                        <Button Content="🗑 Clear MailZen Categories from Inbox" Style="{StaticResource SecondaryButton}"
                                Command="{Binding ClearInboxCategoriesCommand}" HorizontalAlignment="Left"
                                ToolTip="Wipes MailZen: category tags from every email in the selected accounts' Inbox."/>

                        <TextBlock Text="{Binding ClearInboxCategoriesResult}" FontSize="12" Margin="0,8,0,0"
                                   Foreground="#2E7D32" TextWrapping="Wrap"
                                   Visibility="{Binding ClearInboxCategoriesResult, Converter={StaticResource NullToCollapsedConverter}}"/>

                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <!-- ═══ TAB 2: Color Coding Test ═══ -->
                            <TabItem Header="🎨 Color Test" FontSize="13">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="0,12,0,0">

                        <TextBlock Text="Test Color Coding" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="Verify that MailZen color coding works on your email accounts. Select accounts, load a preview, then run the test."
                                   TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16"/>

                        <!-- Account checkboxes -->
                        <TextBlock Text="Select Accounts to Test:" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding ColorTestAccounts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsChecked}" Margin="0,3">
                                        <TextBlock Text="{Binding Name}" FontSize="13"/>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Load Preview button -->
                        <Button Content="🔍 Load Email Preview" Command="{Binding LoadColorTestPreviewCommand}"
                                Height="34" Margin="0,12,0,0" HorizontalAlignment="Left" Padding="16,0"
                                Background="#1565C0" Foreground="White" FontWeight="SemiBold"
                                IsEnabled="{Binding IsColorTestRunning, Converter={StaticResource InverseBoolConverter}}"/>

                        <!-- Loading indicator -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                    Visibility="{Binding IsColorTestRunning, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="⏳" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ColorTestStatus}" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Email preview list -->
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Margin="0,12,0,0"
                                Visibility="{Binding ColorTestPreviewLoaded, Converter={StaticResource BoolToVis}}">
                            <ItemsControl ItemsSource="{Binding ColorTestEmails}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,8" BorderBrush="#F0F0F0" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="6"/>
                                                    <ColumnDefinition Width="190"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Color indicator bar -->
                                                <Border Grid.Column="0" CornerRadius="3" Margin="0,0,10,0"
                                                        Background="{Binding DisplayColor, Converter={StaticResource StringToColorBrushConverter}}"/>

                                                <!-- Account -->
                                                <TextBlock Grid.Column="1" Text="{Binding AccountName}" FontSize="11"
                                                           Foreground="#455A64" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" Margin="10,0,10,0"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <!-- Email info -->
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock FontSize="12" FontWeight="Bold"
                                                               Foreground="{Binding DisplayColor, Converter={StaticResource StringToColorBrushConverter}}">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0}">
                                                                <Binding Path="Sender"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding SubjectSnippet}" FontSize="11"
                                                               Foreground="#666" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Category}" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{Binding DisplayColor, Converter={StaticResource StringToColorBrushConverter}}"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <!-- Date -->
                                                <TextBlock Grid.Column="3" Text="{Binding ReceivedDate}" FontSize="10"
                                                           Foreground="#999" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- Status text (when not running) -->
                        <TextBlock Text="{Binding ColorTestStatus}" TextWrapping="Wrap" Margin="0,8,0,0"
                                   FontSize="12" Foreground="#666"
                                   Visibility="{Binding IsColorTestRunning, Converter={StaticResource InverseBoolToVisConverter}}"/>

                        <!-- Run Test button -->
                        <Button Content="▶ Run Color Coding Test" Command="{Binding RunColorTestCommand}"
                                Height="36" Margin="0,12,0,0" HorizontalAlignment="Left" Padding="20,0"
                                Background="#E65100" Foreground="White" FontWeight="Bold"
                                Visibility="{Binding ColorTestPreviewLoaded, Converter={StaticResource BoolToVis}}"
                                IsEnabled="{Binding IsColorTestRunning, Converter={StaticResource InverseBoolConverter}}"
                                ToolTip="Apply categories and conditional formatting to the previewed emails."/>

                        <!-- Post-test confirmation -->
                        <Border Background="#E8F5E9" CornerRadius="8" Padding="16,12" Margin="0,12,0,0"
                                Visibility="{Binding ColorTestCompleted, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="✅ Test Applied!" FontSize="14" FontWeight="Bold" Foreground="#2E7D32" Margin="0,0,0,6"/>
                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#424242">
                                    Open your Inbox in Outlook and check if the tested emails show colored text:
                                </TextBlock>
                                <StackPanel Margin="8,6,0,0">
                                    <TextBlock Text="• RED bold = MailZen: Delete" Foreground="#D32F2F" FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Text="• ORANGE bold = MailZen: Review" Foreground="#E65100" FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Text="• GREEN bold = MailZen: Keep" Foreground="#2E7D32" FontWeight="Bold" FontSize="12"/>
                                </StackPanel>
                                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#666" Margin="0,8,0,0">
                                    If the colors appear correctly, MailZen is fully compatible with your setup.
                                </TextBlock>

                                <Button Content="🗑 Clean Up Test Categories" Command="{Binding CleanUpColorTestCommand}"
                                        Height="30" Margin="0,10,0,0" HorizontalAlignment="Left" Padding="14,0"
                                        Background="#757575" Foreground="White" FontWeight="SemiBold" FontSize="11"
                                        IsEnabled="{Binding IsColorTestRunning, Converter={StaticResource InverseBoolConverter}}"
                                        ToolTip="Remove all MailZen test categories from the previewed emails."/>
                            </StackPanel>
                        </Border>

                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </StackPanel>
                </Border>

                <!-- ═══ WORKFLOW PIPELINE ═══ -->
                <StackPanel Visibility="{Binding ShowSettings, Converter={StaticResource InverseBoolToVisConverter}}">

                    <!-- ── STEP INDICATOR (horizontal progress bar) ── -->
                    <Border Style="{StaticResource CardBorder}" Padding="24,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Step 1: Connect -->
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <Border Width="38" Height="38" CornerRadius="19" HorizontalAlignment="Center"
                                        Background="{Binding Step1Color, Converter={StaticResource StringToColorBrushConverter}}">
                                    <TextBlock Text="1" FontSize="16" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Connect" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Connector line -->
                            <Border Grid.Column="1" Height="3" Width="40" VerticalAlignment="Center" Margin="0,0,0,16"
                                    Background="{Binding Step2Color, Converter={StaticResource StringToColorBrushConverter}}" CornerRadius="2"/>

                            <!-- Step 2: Learn -->
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <Border Width="38" Height="38" CornerRadius="19" HorizontalAlignment="Center"
                                        Background="{Binding Step2Color, Converter={StaticResource StringToColorBrushConverter}}">
                                    <TextBlock Text="2" FontSize="16" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Learn" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>

                            <Border Grid.Column="3" Height="3" Width="40" VerticalAlignment="Center" Margin="0,0,0,16"
                                    Background="{Binding Step3Color, Converter={StaticResource StringToColorBrushConverter}}" CornerRadius="2"/>

                            <!-- Step 3: Triage -->
                            <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                <Border Width="38" Height="38" CornerRadius="19" HorizontalAlignment="Center"
                                        Background="{Binding Step3Color, Converter={StaticResource StringToColorBrushConverter}}">
                                    <TextBlock Text="3" FontSize="16" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Triage" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>

                            <Border Grid.Column="5" Height="3" Width="40" VerticalAlignment="Center" Margin="0,0,0,16"
                                    Background="{Binding Step4Color, Converter={StaticResource StringToColorBrushConverter}}" CornerRadius="2"/>

                            <!-- Step 4: Review -->
                            <StackPanel Grid.Column="6" HorizontalAlignment="Center">
                                <Border Width="38" Height="38" CornerRadius="19" HorizontalAlignment="Center"
                                        Background="{Binding Step4Color, Converter={StaticResource StringToColorBrushConverter}}">
                                    <TextBlock Text="4" FontSize="16" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Review" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>

                            <Border Grid.Column="7" Height="3" Width="40" VerticalAlignment="Center" Margin="0,0,0,16"
                                    Background="{Binding Step5Color, Converter={StaticResource StringToColorBrushConverter}}" CornerRadius="2"/>

                            <!-- Step 5: Automate -->
                            <StackPanel Grid.Column="8" HorizontalAlignment="Center">
                                <Border Width="38" Height="38" CornerRadius="19" HorizontalAlignment="Center"
                                        Background="{Binding Step5Color, Converter={StaticResource StringToColorBrushConverter}}">
                                    <TextBlock Text="5" FontSize="16" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Automate" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ── STEP 1: CONNECTING (auto, no button) ── -->
                    <Border Style="{StaticResource CardBorder}"
                            Visibility="{Binding CurrentStep, Converter={StaticResource StringEqualsToVisConverter}, ConverterParameter=Connect}">
                        <StackPanel>
                            <TextBlock Text="🔌 Connecting to Outlook..." FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock Text="MailZen is connecting to Outlook Desktop and setting up the AI engine."
                                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16" TextWrapping="Wrap"/>

                            <!-- Progress -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                        Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="⏳" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Error -->
                            <Border Background="#FFEBEE" CornerRadius="6" Padding="14,12" Margin="0,8,0,0"
                                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="⚠️" FontSize="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap"
                                                   Foreground="#C62828" FontSize="13"/>
                                    </StackPanel>
                                    <Button Content="🔄  Retry" Style="{StaticResource SecondaryButton}"
                                            Command="{Binding RetryConnectCommand}" Margin="0,10,0,0"
                                            HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── STEP 2: LEARNING (AI scans deleted items) ── -->
                    <Border Style="{StaticResource CardBorder}"
                            Visibility="{Binding CurrentStep, Converter={StaticResource StringEqualsToVisConverter}, ConverterParameter=Learn}">
                        <StackPanel>
                            <TextBlock Text="🧠 Learning Your Habits" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16">
                                <Run Text="MailZen uses a local AI to learn what you delete and identify junk in your inbox."/>
                            </TextBlock>

                            <!-- ── AI NOT READY: Setup prompt (shown for new users) ── -->
                            <Border Background="#FFF3E0" CornerRadius="8" Padding="18,14" Margin="0,0,0,16"
                                    Visibility="{Binding IsAiReady, Converter={StaticResource InverseBoolToVisConverter}}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="🤖" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="AI Engine Setup Required" FontSize="14" FontWeight="Bold"
                                                   Foreground="#E65100" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#424242" Margin="0,0,0,12">
                                        <Run Text="MailZen needs "/>
                                        <Run Text="Ollama" FontWeight="Bold"/>
                                        <Run Text=" (a free, private AI engine) to analyse your email. Everything runs locally on your computer — no data is sent anywhere."/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#757575" Margin="0,0,0,12">
                                        <Run Text="This is a one-time setup. It will download ~2.5 GB for the AI model. You'll need an internet connection."/>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="📥  Install Ollama + AI Model" Style="{StaticResource PrimaryButton}"
                                                Command="{Binding InstallOllamaCommand}" Margin="0,0,12,0"
                                                IsEnabled="{Binding IsInstallingOllama, Converter={StaticResource InverseBoolConverter}}"/>
                                        <StackPanel Orientation="Horizontal"
                                                    Visibility="{Binding IsInstallingOllama, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="⏳" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                                                       Foreground="#E65100" VerticalAlignment="Center"
                                                       MaxWidth="400" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Account selector for multi-account -->
                            <StackPanel Visibility="{Binding ShowAccountPicker, Converter={StaticResource BoolToVis}}" Margin="0,0,0,16">
                                <TextBlock Text="Select an account to start with:" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <ListBox ItemsSource="{Binding Accounts}" SelectedItem="{Binding SelectedAccount}"
                                         BorderThickness="0" Background="Transparent" Padding="0">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="itemBorder" Background="#F8F9FC" CornerRadius="8"
                                                                Padding="14,10" Margin="0,0,0,6" BorderThickness="2"
                                                                BorderBrush="#E5E7EB" Cursor="Hand">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="itemBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                                <Setter TargetName="itemBorder" Property="Background" Value="#EDE7F6"/>
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="itemBorder" Property="Background" Value="#F0EDFF"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📬" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding EmailAddress}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                <Border Background="#EDE7F6" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ProviderHint}" FontSize="10" Foreground="#5A52D5" FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>

                            <Button Content="▶️  Start Learning" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding StartLearningCommand}" HorizontalAlignment="Left" Margin="0,0,0,16"
                                    Visibility="{Binding ShowStartLearning, Converter={StaticResource BoolToVis}}"
                                    IsEnabled="{Binding IsAiReady}"/>

                            <!-- Progress -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                        Visibility="{Binding IsLearning, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="⏳" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Stop button (visible while running) -->
                            <Button Content="⏹  Stop" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding StopOperationCommand}" HorizontalAlignment="Left" Margin="0,4,0,8"
                                    Visibility="{Binding CanStop, Converter={StaticResource BoolToVis}}"/>

                            <!-- Stopped state: Resume / Skip to Triage -->
                            <StackPanel Visibility="{Binding WasStopped, Converter={StaticResource BoolToVis}}"
                                        Margin="0,4,0,0">
                                <TextBlock Text="{Binding StatusMessage}" FontSize="13" Margin="0,0,0,12"
                                           Foreground="#E65100" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="▶️  Resume" Style="{StaticResource PrimaryButton}"
                                            Command="{Binding ResumeCommand}" Margin="0,0,12,0"/>
                                    <Button Content="⏩  Skip to Triage" Style="{StaticResource SecondaryButton}"
                                            Command="{Binding SkipToTriageCommand}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Error state -->
                            <Border Background="#FFEBEE" CornerRadius="6" Padding="14,12" Margin="0,8,0,0"
                                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="⚠️" FontSize="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap"
                                                   Foreground="#C62828" FontSize="13"/>
                                    </StackPanel>
                                    <Button Content="🔄  Retry" Style="{StaticResource SecondaryButton}"
                                            Command="{Binding StartLearningCommand}" Margin="0,10,0,0"
                                            HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── STEP 3: TRIAGE (AI scans inbox, moves to Review) ── -->
                    <Border Style="{StaticResource CardBorder}"
                            Visibility="{Binding CurrentStep, Converter={StaticResource StringEqualsToVisConverter}, ConverterParameter=Triage}">
                        <StackPanel>
                            <TextBlock Text="📧 Scanning Your Inbox" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16">
                                <Run Text="The AI is now scanning your inbox emails and identifying ones you probably don't want. Matches will be moved to the "/>
                                <Run Text="Review for Deletion" FontWeight="Bold"/>
                                <Run Text=" folder in Outlook."/>
                            </TextBlock>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                        Visibility="{Binding IsTriaging, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="⏳" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Stop button (visible while triage is running) -->
                            <Button Content="⏹  Stop" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding StopOperationCommand}" HorizontalAlignment="Left" Margin="0,4,0,8"
                                    Visibility="{Binding CanStop, Converter={StaticResource BoolToVis}}"/>

                            <!-- Stopped state: Resume / Skip to Review -->
                            <StackPanel Visibility="{Binding WasStopped, Converter={StaticResource BoolToVis}}"
                                        Margin="0,4,0,0">
                                <TextBlock Text="{Binding StatusMessage}" FontSize="13" Margin="0,0,0,12"
                                           Foreground="#E65100" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="▶️  Resume Triage" Style="{StaticResource PrimaryButton}"
                                            Command="{Binding ResumeCommand}" Margin="0,0,12,0"/>
                                    <Button Content="📂  Review What's Moved" Style="{StaticResource SecondaryButton}"
                                            Command="{Binding ContinueAfterReviewCommand}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Error state -->
                            <Border Background="#FFEBEE" CornerRadius="6" Padding="14,12" Margin="0,8,0,0"
                                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="⚠️" FontSize="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap"
                                                   Foreground="#C62828" FontSize="13"/>
                                    </StackPanel>
                                    <Button Content="🔄  Retry" Style="{StaticResource SecondaryButton}"
                                            Command="{Binding ResumeCommand}" Margin="0,10,0,0"
                                            HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── STEP 4: REVIEW (Handoff — user reviews in Outlook) ── -->
                    <Border Style="{StaticResource CardBorder}"
                            Visibility="{Binding CurrentStep, Converter={StaticResource StringEqualsToVisConverter}, ConverterParameter=Review}">
                        <StackPanel>
                            <TextBlock Text="📂 Review in Outlook" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>

                            <Border CornerRadius="8" Padding="20,16" Margin="0,0,0,16">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FFF8E1" Offset="0"/>
                                        <GradientStop Color="#FFF3E0" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <TextBlock FontSize="14" Foreground="#212121" TextWrapping="Wrap" Margin="0,0,0,8">
                                        <Run Text="I moved " FontWeight="SemiBold"/>
                                        <Run Text="{Binding ReviewCount, Mode=OneWay}" FontWeight="Bold" Foreground="#D32F2F"/>
                                        <Run Text=" emails to the " FontWeight="SemiBold"/>
                                        <Run Text="Review for Deletion" FontWeight="Bold" Foreground="#E65100"/>
                                        <Run Text=" folder." FontWeight="SemiBold"/>
                                    </TextBlock>
                                    <TextBlock FontSize="14" Foreground="#212121" TextWrapping="Wrap" Margin="0,0,0,6">
                                        <Run Text="1. Open Outlook → Review for Deletion"/>
                                    </TextBlock>
                                    <TextBlock FontSize="14" Foreground="#212121" TextWrapping="Wrap" Margin="0,0,0,6">
                                        <Run Text="2. Delete the emails you agree are junk"/>
                                    </TextBlock>
                                    <TextBlock FontSize="14" Foreground="#212121" TextWrapping="Wrap" Margin="0,0,0,6">
                                        <Run Text="3. Leave the ones you want to keep"/>
                                    </TextBlock>
                                    <TextBlock FontSize="14" Foreground="#212121" TextWrapping="Wrap">
                                        <Run Text="4. Come back here and click "/>
                                        <Run Text="Continue" FontWeight="Bold"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="✅  Continue" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ContinueAfterReviewCommand}" Margin="0,0,12,0"
                                        IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"/>
                                <StackPanel Orientation="Horizontal"
                                            Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="⏳" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── STEP 5: AUTOMATE (Results + Rules Created) ── -->
                    <Border Style="{StaticResource CardBorder}"
                            Visibility="{Binding CurrentStep, Converter={StaticResource StringEqualsToVisConverter}, ConverterParameter=Automate}">
                        <StackPanel>
                            <TextBlock Text="✅ Cleanup Complete!" FontSize="18" FontWeight="Bold"
                                       Foreground="#2E7D32" Margin="0,0,0,8"/>

                            <!-- Results Summary -->
                            <Border CornerRadius="8" Padding="20,16" Margin="0,0,0,16">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#E8F5E9" Offset="0"/>
                                        <GradientStop Color="#EDE7F6" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding DeletedCount, Mode=OneWay}" FontSize="28" FontWeight="Bold"
                                                       Foreground="#D32F2F" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Deleted (Junk)" FontSize="11" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding KeptCount, Mode=OneWay}" FontSize="28" FontWeight="Bold"
                                                       Foreground="#2E7D32" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Kept → Inbox" FontSize="11" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding RulesCreatedCount, Mode=OneWay}" FontSize="28" FontWeight="Bold"
                                                       Foreground="#6C63FF" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Rules Created" FontSize="11" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                                               Foreground="#555" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                </StackPanel>
                            </Border>

                            <Button Content="🔄  Run Again" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding RunAgainCommand}" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Inbox Review" FontSize="16" FontWeight="SemiBold">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left: Configuration -->
                    <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20" Margin="0,0,20,0">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,8" LastChildFill="False">
                                <TextBlock Text="1. Choose Account" FontWeight="Bold" FontSize="14" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                <CheckBox Content="Select All" DockPanel.Dock="Right" VerticalAlignment="Center"
                                          IsChecked="True"
                                          Command="{Binding ToggleSelectAllCommand}"
                                          CommandParameter="{Binding IsChecked, RelativeSource={RelativeSource Self}}"/>
                            </DockPanel>
                            <TextBlock Text="Inbox Review actions use exactly one account at a time. Advanced tools can still use multiple accounts."
                                       TextWrapping="Wrap" Foreground="#666" FontSize="11" Margin="0,0,0,10"/>

                            <ListBox ItemsSource="{Binding AvailableAccounts}" Height="350" BorderThickness="1" BorderBrush="#E0E0E0" Margin="0,0,0,16">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="5"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <TextBlock Text="2. Inbox Review Scope" FontWeight="Bold" Margin="0,0,0,8" FontSize="14"/>
                            <StackPanel Margin="5,0,0,0">
                                <TextBlock Text="Categorize Inbox always scans the Inbox and applies MailZen categories in Outlook."
                                           TextWrapping="Wrap" Foreground="#666" FontSize="11" Margin="0,0,0,8"/>
                                <CheckBox Content="Include read Inbox mail too" IsChecked="{Binding DatasetIncludeRead}"
                                          Margin="0,4" FontSize="12"
                                          ToolTip="Leave this unchecked to focus only on unread Inbox mail."/>
                                <CheckBox Content="Include Sent Items in Advanced Tools" IsChecked="{Binding DatasetIncludeSent}" Margin="0,4" FontSize="12"/>
                                <CheckBox Content="Include Deleted Items in Advanced Tools" IsChecked="{Binding DatasetIncludeDeleted}" Margin="0,4" FontSize="12"/>
                            </StackPanel>

                            <TextBlock Text="3. Date Range" FontWeight="Bold" Margin="0,16,0,8" FontSize="14"/>
                            <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                                <DatePicker SelectedDate="{Binding DatasetStartDate}" Width="110"/>
                                <TextBlock Text=" to " VerticalAlignment="Center" Margin="5,0"/>
                                <DatePicker SelectedDate="{Binding DatasetEndDate}" Width="110"/>
                            </StackPanel>

                            <TextBlock Text="4. Output" FontWeight="Bold" Margin="0,16,0,8" FontSize="14"/>
                            <CheckBox Content="Also save XLSX workbook (3-sheet report)" IsChecked="{Binding DatasetSaveXlsx}"
                                      Margin="5,0,0,0" FontSize="12"/>
                            <TextBlock Text="MailZen always applies Keep / Review / Delete categories during Inbox Review. The checkbox above only controls the extra XLSX report."
                                       TextWrapping="Wrap" Foreground="#666" FontSize="11" Margin="5,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Right: Status & Actions -->
                    <StackPanel Grid.Column="1">
                        <Border Background="#F5F7FA" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Inbox Review" FontSize="18" FontWeight="Bold" Foreground="#333" Margin="0,0,0,6"/>
                                <TextBlock Text="Tag one Inbox with MailZen categories, review the results directly in Outlook, then sync the final Keep/Delete outcomes back into MailZen."
                                           TextWrapping="Wrap" Foreground="#666" Margin="0,0,0,16"/>

                                <Border Background="White" CornerRadius="8" Padding="16" BorderBrush="#E5E7EB" BorderThickness="1" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="{Binding InboxReviewSummary}" TextWrapping="Wrap" FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding InboxReviewLastRun}" TextWrapping="Wrap" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding InboxReviewSyncSummary}" TextWrapping="Wrap" FontSize="12"
                                                   Foreground="#1565C0"/>
                                    </StackPanel>
                                </Border>

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="🏷 Categorize Inbox" Command="{Binding RunInboxReviewCommand}"
                                            Width="170" Height="40" Background="#4CAF50" Foreground="White" FontWeight="Bold"
                                            IsEnabled="{Binding IsDatasetRunning, Converter={StaticResource InverseBoolConverter}}"/>
                                    <Button Content="🔄 Sync Review + Relearn" Command="{Binding SyncInboxReviewCommand}"
                                            Width="200" Height="40" Margin="10,0,0,0" Background="#1565C0" Foreground="White"
                                            FontWeight="SemiBold"
                                            Visibility="{Binding HasInboxReviewSession, Converter={StaticResource BoolToVis}}"
                                            IsEnabled="{Binding IsInboxReviewSyncRunning, Converter={StaticResource InverseBoolConverter}}"/>
                                    <Button Content="Cancel" Command="{Binding CancelDatasetCommand}"
                                            Width="100" Height="40" Margin="10,0,0,0" Background="#F44336" Foreground="White"
                                            Visibility="{Binding IsDatasetRunning, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                                <ProgressBar IsIndeterminate="True" Height="4" Margin="0,15,0,0"
                                             Visibility="{Binding IsDatasetRunning, Converter={StaticResource BoolToVis}}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                                            Visibility="{Binding IsInboxReviewSyncRunning, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="⏳" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding DatasetStatus}" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Advanced Tools" FontSize="16" FontWeight="Bold" Foreground="#333" Margin="0,0,0,6"/>
                                <TextBlock Text="Use these when you want a traditional export or to re-score a saved CSV outside the main Inbox Review loop."
                                           TextWrapping="Wrap" Foreground="#666" Margin="0,0,0,16"/>

                                <TextBlock Text="Mode:" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <RadioButton Content="Extract from Outlook" IsChecked="{Binding DatasetModeIsExtract}"
                                                 Margin="0,0,20,0" FontSize="13" VerticalAlignment="Center"/>
                                    <RadioButton Content="Re-score existing CSV"
                                                 IsChecked="{Binding DatasetModeIsExtract, Converter={StaticResource InverseBoolConverter}}"
                                                 FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Visibility="{Binding DatasetModeIsExtract, Converter={StaticResource InverseBoolToVisConverter}}"
                                            Margin="0,0,0,12">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Button Content="📂 Browse CSV" Command="{Binding BrowseDatasetCommand}"
                                                Width="120" Height="32" Background="#1565C0" Foreground="White" FontWeight="SemiBold"
                                                IsEnabled="{Binding IsDatasetRunning, Converter={StaticResource InverseBoolConverter}}"/>
                                        <TextBlock Text="{Binding ScoreDatasetPath}" VerticalAlignment="Center" Margin="10,0,0,0"
                                                   FontSize="11" Foreground="#555" TextTrimming="CharacterEllipsis" MaxWidth="260"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding ScoreDatasetValidation}" FontSize="12" Foreground="#333" TextWrapping="Wrap"/>
                                </StackPanel>

                                <CheckBox IsChecked="{Binding ApplyOutlookCategories}" Margin="0,0,0,16"
                                          ToolTip="When enabled, advanced extract or re-score runs also write MailZen categories back into Outlook.">
                                    <TextBlock Text="Apply MailZen categories during advanced tools runs" TextWrapping="Wrap"/>
                                </CheckBox>

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="▶ Run Advanced Tool" Command="{Binding RunDatasetCommand}"
                                            Width="168" Height="40" Background="#4CAF50" Foreground="White" FontWeight="Bold"
                                            IsEnabled="{Binding IsDatasetRunning, Converter={StaticResource InverseBoolConverter}}"/>
                                    <Button Content="💾 Save Defaults" Command="{Binding SaveDatasetDefaultsCommand}"
                                            Width="130" Height="40" Margin="10,0,0,0"
                                            Background="#7C4DFF" Foreground="White" FontWeight="SemiBold"
                                            ToolTip="Save current account selections, date range, and advanced options as your defaults."
                                            IsEnabled="{Binding IsDatasetRunning, Converter={StaticResource InverseBoolConverter}}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="White" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Status Log" FontWeight="Bold" Margin="0,0,0,10"/>
                                <ScrollViewer Height="150" VerticalScrollBarVisibility="Auto">
                                    <TextBlock Text="{Binding DatasetStatus}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="2" Padding="20,8">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Color="#1E1E2E" Offset="0"/>
                    <GradientStop Color="#2D2D44" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusBarText}"
                           FontSize="11" Foreground="#A0A3BD" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding AppVersion, StringFormat='✨ MailZen v{0}'}"
                           FontSize="10" Foreground="#6B7290" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
