                                        <TextBlock Text="{Binding LastLearnResult.NewPatternsAdded, StringFormat='New rules added: {0}'}" FontSize="15" FontWeight="Bold" Foreground="#6C63FF" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding LastLearnResult.TotalPatterns, StringFormat='Total rules now: {0}'}" FontSize="14" Foreground="#212121" Margin="0,0,0,12"/>
                                        <TextBlock Text="Now go to Run Triage to apply the updated rules to your inbox!" FontSize="13" Foreground="#555" FontStyle="Italic"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- IMPROVE MODEL VIEW -->
                    <StackPanel Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisConverter}, ConverterParameter=Improve}">
                        <TextBlock Text="Improve Model" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                        <TextBlock Text="Review emails in Outlook's 'Needs Review' folder — delete what's junk — then come back and click Done. MailZen learns from your choices."
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20" TextWrapping="Wrap"/>

                        <!-- Step 1: Start Review -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="📋 Step 1: Start Review" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="Takes a snapshot of your Needs Review folder, then sends you to Outlook to review."
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16" TextWrapping="Wrap"/>

                                <Button Content="🔄  Start Review"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding StartReviewCommand}"
                                        IsEnabled="{Binding IsLoadingReview, Converter={StaticResource InverseBoolConverter}}"
                                        HorizontalAlignment="Left" Margin="0,0,0,12"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                            Visibility="{Binding IsLoadingReview, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="⏳" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="Checking folder..." FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>

                                <TextBlock Text="{Binding ImproveProgress}" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Step 2: Waiting for user — shown when review is active -->
                        <Border Style="{StaticResource CardBorder}"
                                Visibility="{Binding IsImproveReviewing, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <Border CornerRadius="8" Padding="20,18" Margin="0,0,0,12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FFF8E1" Offset="0"/>
                                            <GradientStop Color="#FFF3E0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel>
                                        <TextBlock Text="📂 Your Task" FontSize="17" FontWeight="Bold" Foreground="#E65100" Margin="0,0,0,10"/>
                                        <TextBlock FontSize="14" Foreground="#212121" TextWrapping="Wrap" Margin="0,0,0,6">
                                            <Run Text="1. Open Outlook → Smart Cleanup → Needs Review"/>
                                        </TextBlock>
                                        <TextBlock FontSize="14" Foreground="#212121" TextWrapping="Wrap" Margin="0,0,0,6">
                                            <Run Text="2. Delete the emails you consider junk"/>
                                        </TextBlock>
                                        <TextBlock FontSize="14" Foreground="#212121" TextWrapping="Wrap" Margin="0,0,0,6">
                                            <Run Text="3. Leave the ones you want to keep"/>
                                        </TextBlock>
                                        <TextBlock FontSize="14" Foreground="#212121" TextWrapping="Wrap">
                                            <Run Text="4. Come back here and click "/>
                                            <Run Text="Done Reviewing" FontWeight="Bold"/>
                                        </TextBlock>
                                        <Border Background="#FFE082" CornerRadius="6" Padding="12,8" Margin="0,14,0,0">
                                            <TextBlock FontSize="13" Foreground="#5D4037" FontWeight="SemiBold">
                                                <Run Text="📬 "/>
                                                <Run Text="{Binding ImproveNeedsReviewCount, Mode=OneWay}"/>
                                                <Run Text=" emails waiting for your review"/>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="✅  Done Reviewing" Style="{StaticResource PrimaryButton}"
                                            Command="{Binding DoneReviewingImproveCommand}"
                                            IsEnabled="{Binding IsProcessingAction, Converter={StaticResource InverseBoolConverter}}"
                                            Margin="0,0,12,0"/>
                                    <StackPanel Orientation="Horizontal"
                                                Visibility="{Binding IsProcessingAction, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="⏳" FontSize="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="Processing..." FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Results after review -->
                        <Border Style="{StaticResource CardBorder}"
                                Visibility="{Binding ImproveShowResults, Converter={StaticResource BoolToVis}}">
                            <Border CornerRadius="8" Padding="20,18">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#E8F5E9" Offset="0"/>
                                        <GradientStop Color="#EDE7F6" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <TextBlock Text="✅ Review Complete" FontWeight="Bold" Foreground="#2E7D32" FontSize="17" Margin="0,0,0,14"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding ImproveDeletedCount, Mode=OneWay}" FontSize="28" FontWeight="Bold" Foreground="#D32F2F" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Deleted (Junk)" FontSize="11" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding ImproveKeptCount, Mode=OneWay}" FontSize="28" FontWeight="Bold" Foreground="#2E7D32" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Kept → Inbox" FontSize="11" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding ImproveNewRulesAdded, Mode=OneWay}" FontSize="28" FontWeight="Bold" Foreground="#6C63FF" HorizontalAlignment="Center"/>
                                            <TextBlock Text="New Rules" FontSize="11" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="Run Triage again to apply your updated rules." FontSize="13" Foreground="#555" Margin="0,14,0,0" FontStyle="Italic"/>
                                </StackPanel>
                            </Border>
                        </Border>
                    </StackPanel>

                    <!-- TRIAGE VIEW -->
                    <StackPanel Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisConverter}, ConverterParameter=Triage}">
                        <TextBlock Text="Run Triage" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                        <TextBlock Text="Scan your inbox and move emails to Smart Cleanup folders based on your patterns."
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20"/>

                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Inbox Triage" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                                <TextBlock Text="{Binding SelectedAccount.EmailAddress, StringFormat='Account: {0}'}" 
                                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,16"/>

                                <Button Content="📁  Run Triage Now"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding RunTriageCommand}"
                                        IsEnabled="{Binding IsTriaging, Converter={StaticResource InverseBoolConverter}}"
                                        HorizontalAlignment="Left" Margin="0,0,0,16"/>

                                <StackPanel Visibility="{Binding IsTriaging, Converter={StaticResource BoolToVis}}" Margin="0,0,0,16">
                                    <TextBlock Text="⏳" FontSize="16" Margin="0,0,8,0" HorizontalAlignment="Left"/>
                                    <TextBlock Text="{Binding TriageProgress}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>

                                <Border CornerRadius="8" Padding="20,18" 
                                        Visibility="{Binding LastTriageResult, Converter={StaticResource NullToCollapsedConverter}}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#EDE7F6" Offset="0"/>
                                            <GradientStop Color="#E3F2FD" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel>
                                        <TextBlock Text="✅ Triage Complete" FontWeight="Bold" Foreground="#5A52D5" FontSize="17" Margin="0,0,0,14"/>
                                        <TextBlock Text="{Binding LastTriageResult.ScannedCount, StringFormat='Inbox items scanned: {0}'}" FontSize="15" Foreground="#212121" Margin="0,0,0,6"/>
                                        <TextBlock Text="{Binding LastTriageResult.MovedToDeleteCandidates, StringFormat='Moved to Delete Candidates: {0}'}" FontSize="15" FontWeight="Bold" Foreground="#D32F2F" Margin="0,0,0,6"/>
                                        <TextBlock Text="{Binding LastTriageResult.MovedToNeedsReview, StringFormat='Moved to Needs Review: {0}'}" FontSize="15" FontWeight="Bold" Foreground="#F57C00" Margin="0,0,0,6"/>
                                        
                                        <TextBlock Text="Check your Outlook 'Smart Cleanup' folder to review the results." FontSize="13" Foreground="#555555" Margin="0,12,0,0" FontStyle="Italic"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- AI SMART SCAN VIEW -->
                    <StackPanel Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisConverter}, ConverterParameter=AiScan}">
                        <TextBlock Text="AI Smart Scan" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                        <TextBlock Text="Use local AI (Ollama) to find junk emails that rules missed. AI flags them, moves them to a folder — you review in Outlook."
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20" TextWrapping="Wrap"/>

                        <!-- ═══ AI SETUP CARD ═══ -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="🤖 AI Engine Setup" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <Border CornerRadius="4" Padding="8,4" Margin="12,0,0,0" VerticalAlignment="Center"
                                            Background="{Binding AiStatusColor, Converter={StaticResource StringToColorBrushConverter}}">
                                        <TextBlock Text="{Binding AiStatus}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="One-click setup: installs Ollama and downloads the AI model automatically."
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16" TextWrapping="Wrap"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button Content="⚡ Setup AI (One Click)"
                                            Style="{StaticResource PrimaryButton}"
                                            Command="{Binding SetupAiCommand}"
                                            IsEnabled="{Binding IsAiSetupRunning, Converter={StaticResource InverseBoolConverter}}"
                                            Margin="0,0,12,0"/>
                                    <Button Content="🔄 Check for Updates" Style="{StaticResource SecondaryButton}"
                                            Command="{Binding CheckAiUpdatesCommand}"
                                            IsEnabled="{Binding IsAiSetupRunning, Converter={StaticResource InverseBoolConverter}}"
                                            Visibility="{Binding IsAiReady, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>

                                <!-- Setup progress -->
                                <StackPanel Visibility="{Binding IsAiSetupRunning, Converter={StaticResource BoolToVis}}" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⏳" FontSize="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding AiSetupProgress}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- AI Info when ready -->
                                <Border CornerRadius="8" Padding="16,12" Margin="0,4,0,0"
                                        Visibility="{Binding IsAiReady, Converter={StaticResource BoolToVis}}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#E8F5E9" Offset="0"/>
                                            <GradientStop Color="#E3F2FD" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <Border Background="#C8E6C9" CornerRadius="4" Padding="8,3" Margin="0,0,8,0">
                                                <TextBlock FontSize="11" Foreground="#1B5E20" FontWeight="SemiBold">
                                                    <Run Text="Ollama v"/><Run Text="{Binding AiOllamaVersion, Mode=OneWay}"/>
                                                </TextBlock>
                                            </Border>
                                            <Border Background="#BBDEFB" CornerRadius="4" Padding="8,3" Margin="0,0,8,0">
                                                <TextBlock FontSize="11" Foreground="#0D47A1" FontWeight="SemiBold">
                                                    <Run Text="Model: "/><Run Text="{Binding AiModelName, Mode=OneWay}"/>
                                                </TextBlock>
                                            </Border>
                                            <Border Background="#E1BEE7" CornerRadius="4" Padding="8,3">
                                                <TextBlock FontSize="11" Foreground="#4A148C" FontWeight="SemiBold">
                                                    <Run Text="{Binding AiModelSize, Mode=OneWay}"/>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding AiSetupProgress}" FontSize="12" Foreground="#555" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ═══ AI SCAN CARD ═══ -->
                        <Border Style="{StaticResource CardBorder}"
                                Visibility="{Binding IsAiReady, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="📊 Step 1: Run AI Scan" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="Scans up to 100 inbox emails with AI and compares against your rules. Finds emails AI thinks are junk that rules missed."
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16" TextWrapping="Wrap"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button Content="🚀 Run AI Scan"
                                            Style="{StaticResource PrimaryButton}"
                                            Command="{Binding RunAiScanCommand}"
                                            IsEnabled="{Binding IsAiScanning, Converter={StaticResource InverseBoolConverter}}"
                                            Margin="0,0,12,0"/>
                                    <Button Content="❌ Cancel" Style="{StaticResource SecondaryButton}"
                                            Command="{Binding CancelAiScanCommand}"
                                            Visibility="{Binding IsAiScanning, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>

                                <TextBlock Text="{Binding AiScanProgress}" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                            Visibility="{Binding IsAiScanning, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="⏳" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="AI is classifying emails... this may take a few minutes on CPU."
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ═══ SCAN RESULTS + MOVE TO FOLDER ═══ -->
                        <Border Style="{StaticResource CardBorder}"
                                Visibility="{Binding AiShowResults, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <!-- Summary Stats -->
                                <Border CornerRadius="8" Padding="20,18" Margin="0,0,0,16">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#EDE7F6" Offset="0"/>
                                            <GradientStop Color="#E3F2FD" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel>
                                        <TextBlock Text="📊 AI Scan Results" FontWeight="Bold" Foreground="#5A52D5" FontSize="17" Margin="0,0,0,14"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding AiScanTotal, Mode=OneWay}" FontSize="28" FontWeight="Bold" Foreground="#1A1A2E" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Scanned" FontSize="11" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding AiGapCount, Mode=OneWay}" FontSize="28" FontWeight="Bold" Foreground="#D32F2F" HorizontalAlignment="Center"/>
                                                <TextBlock Text="AI Gap (junk)" FontSize="11" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                <TextBlock FontSize="12" Foreground="#888" HorizontalAlignment="Center" Margin="0,6,0,0">
                                                    <Run Text="{Binding AiScanSeconds, Mode=OneWay}"/>
                                                    <Run Text="s / ~"/>
                                                    <Run Text="{Binding AiAvgLatency, Mode=OneWay}"/>
                                                    <Run Text="ms avg"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Step 2: Move to AI Review -->
                                <TextBlock Text="📂 Step 2: Move to AI Review Folder" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12" TextWrapping="Wrap">
                                    <Run Text="Move the "/>
                                    <Run Text="{Binding AiGapCount, Mode=OneWay}" FontWeight="Bold"/>
                                    <Run Text=" AI-flagged emails to Smart Cleanup → AI Review. You'll review and delete junk in Outlook."/>
                                </TextBlock>

                                <Button Content="📁  Move to AI Review Folder"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding MoveToAiReviewCommand}"
                                        IsEnabled="{Binding IsAiScanning, Converter={StaticResource InverseBoolConverter}}"
                                        HorizontalAlignment="Left" Margin="0,0,0,8"/>
                            </StackPanel>
                        </Border>

                        <!-- ═══ REVIEW IN OUTLOOK CARD ═══ -->
                        <Border Style="{StaticResource CardBorder}"
                                Visibility="{Binding IsAiReviewPending, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <Border CornerRadius="8" Padding="20,18" Margin="0,0,0,12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FFF8E1" Offset="0"/>
                                            <GradientStop Color="#FFF3E0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel>
                                        <TextBlock Text="📂 Your Task" FontSize="17" FontWeight="Bold" Foreground="#E65100" Margin="0,0,0,10"/>
                                        <TextBlock FontSize="14" Foreground="#212121" TextWrapping="Wrap" Margin="0,0,0,6">
                                            <Run Text="1. Open Outlook → Smart Cleanup → AI Review"/>
                                        </TextBlock>
                                        <TextBlock FontSize="14" Foreground="#212121" TextWrapping="Wrap" Margin="0,0,0,6">
                                            <Run Text="2. Review the emails AI flagged as junk"/>
                                        </TextBlock>
                                        <TextBlock FontSize="14" Foreground="#212121" TextWrapping="Wrap" Margin="0,0,0,6">
                                            <Run Text="3. Delete the ones you agree are junk"/>
                                        </TextBlock>
                                        <TextBlock FontSize="14" Foreground="#212121" TextWrapping="Wrap">
                                            <Run Text="4. Come back here and click "/>
                                            <Run Text="Done Reviewing" FontWeight="Bold"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="{Binding AiScanProgress}" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12" TextWrapping="Wrap"/>

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="✅  Done Reviewing" Style="{StaticResource PrimaryButton}"
                                            Command="{Binding DoneReviewingAiCommand}"
                                            IsEnabled="{Binding IsAiScanning, Converter={StaticResource InverseBoolConverter}}"
                                            Margin="0,0,12,0"/>
                                    <StackPanel Orientation="Horizontal"
                                                Visibility="{Binding IsAiScanning, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="⏳" FontSize="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="Processing..." FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ═══ MOVE REMAINING BACK ═══ -->
                        <Border Style="{StaticResource CardBorder}"
                                Visibility="{Binding IsAiMoveBackPending, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <Border CornerRadius="8" Padding="20,18" Margin="0,0,0,12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#E8F5E9" Offset="0"/>
                                            <GradientStop Color="#EDE7F6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel>
                                        <TextBlock Text="📊 Review Summary" FontWeight="Bold" Foreground="#5A52D5" FontSize="17" Margin="0,0,0,14"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding AiUserDeletedCount, Mode=OneWay}" FontSize="28" FontWeight="Bold" Foreground="#D32F2F" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Deleted (Agreed)" FontSize="11" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding AiUserKeptCount, Mode=OneWay}" FontSize="28" FontWeight="Bold" Foreground="#F57C00" HorizontalAlignment="Center"/>
                                                <TextBlock Text="Kept (Disagree)" FontSize="11" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding AiNewRulesAdded, Mode=OneWay}" FontSize="28" FontWeight="Bold" Foreground="#6C63FF" HorizontalAlignment="Center"/>
                                                <TextBlock Text="New Rules" FontSize="11" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="{Binding AiScanProgress}" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12" TextWrapping="Wrap"/>

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="📥  Move Remaining Back to Inbox" Style="{StaticResource PrimaryButton}"
                                            Command="{Binding MoveAiRemainingBackCommand}"
                                            IsEnabled="{Binding IsAiScanning, Converter={StaticResource InverseBoolConverter}}"
                                            Margin="0,0,12,0"/>
                                    <StackPanel Orientation="Horizontal"
                                                Visibility="{Binding IsAiScanning, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="⏳" FontSize="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="Moving emails..." FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="2" Padding="20,10">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Color="#1E1E2E" Offset="0"/>
                    <GradientStop Color="#2D2D44" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusBarText}"
                           FontSize="12" Foreground="#A0A3BD" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="✨ MailZen v0.5"
                           FontSize="11" Foreground="#6B7290" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
