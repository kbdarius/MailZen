<Window x:Class="EmailManage.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:EmailManage.ViewModels"
        mc:Ignorable="d"
        Title="{Binding AppTitle}"
        Height="720" Width="1060" MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        Closed="Window_Closed">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header bar -->
            <RowDefinition Height="*"/>      <!-- Content -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER BAR — Gradient ═══ -->
        <Border Grid.Row="0" Padding="24,16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Color="{StaticResource HeaderGradientStartColor}" Offset="0"/>
                    <GradientStop Color="{StaticResource HeaderGradientEndColor}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="✨" FontSize="26" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="MailZen" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="Smart Email Cleanup" FontSize="13" Foreground="#D1C4E9" VerticalAlignment="Center" Margin="16,3,0,0"
                               FontStyle="Italic" Opacity="0.85"/>
                </StackPanel>

                <!-- Connection Status Pill -->
                <Border Grid.Column="2" CornerRadius="16" Padding="14,7" VerticalAlignment="Center"
                        Background="{Binding ConnectionStatusColor, Converter={StaticResource StringToColorBrushConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center" Fill="White"/>
                        <TextBlock Text="{Binding ConnectionStatus}" Foreground="White" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>   <!-- Dark sidebar -->
                <ColumnDefinition Width="*"/>     <!-- Main content -->
            </Grid.ColumnDefinitions>

            <!-- ── DARK SIDEBAR ── -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
                <StackPanel Margin="0,24,0,0">
                    <TextBlock Text="N A V I G A T I O N" FontSize="10" FontWeight="Bold"
                               Foreground="#6B7290" Margin="24,0,0,16"/>

                    <!-- Phase 1: Connect -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="Connect"
                            Background="Transparent" BorderThickness="0" Padding="0" Margin="8,0,8,4" Cursor="Hand">
                        <Border x:Name="navConnect" CornerRadius="8" Padding="16,12"
                                Background="{Binding CurrentView, Converter={StaticResource StringEqualsToBrushConverter}, ConverterParameter=Connect}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔌" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Connect" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"
                                           Foreground="{Binding CurrentView, Converter={StaticResource StringEqualsToForegroundConverter}, ConverterParameter=Connect}"/>
                            </StackPanel>
                        </Border>
                    </Button>

                    <!-- Phase 2: Analyze -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="Analyze"
                            IsEnabled="{Binding IsConnected}"
                            Background="Transparent" BorderThickness="0" Padding="0" Margin="8,0,8,4" Cursor="Hand">
                        <Border CornerRadius="8" Padding="16,12"
                                Background="{Binding CurrentView, Converter={StaticResource StringEqualsToBrushConverter}, ConverterParameter=Analyze}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Analyze Patterns" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"
                                           Foreground="{Binding CurrentView, Converter={StaticResource StringEqualsToForegroundConverter}, ConverterParameter=Analyze}"/>
                            </StackPanel>
                        </Border>
                    </Button>

                    <!-- Phase 3: Triage -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="Triage"
                            IsEnabled="{Binding IsConnected}"
                            Background="Transparent" BorderThickness="0" Padding="0" Margin="8,0,8,4" Cursor="Hand">
                        <Border CornerRadius="8" Padding="16,12"
                                Background="{Binding CurrentView, Converter={StaticResource StringEqualsToBrushConverter}, ConverterParameter=Triage}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📁" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Run Triage" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"
                                           Foreground="{Binding CurrentView, Converter={StaticResource StringEqualsToForegroundConverter}, ConverterParameter=Triage}"/>
                            </StackPanel>
                        </Border>
                    </Button>

                    <!-- Separator -->
                    <Border Height="1" Background="#2D2D44" Margin="20,16,20,16"/>

                    <!-- Phase 4: Improve Model -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="Improve"
                            IsEnabled="{Binding IsConnected}"
                            Background="Transparent" BorderThickness="0" Padding="0" Margin="8,0,8,4" Cursor="Hand">
                        <Border CornerRadius="8" Padding="16,12"
                                Background="{Binding CurrentView, Converter={StaticResource StringEqualsToBrushConverter}, ConverterParameter=Improve}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🧠" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Improve Model" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"
                                           Foreground="{Binding CurrentView, Converter={StaticResource StringEqualsToForegroundConverter}, ConverterParameter=Improve}"/>
                            </StackPanel>
                        </Border>
                    </Button>

                    <!-- Phase 5: AI Smart Scan -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="AiScan"
                            IsEnabled="{Binding IsConnected}"
                            Background="Transparent" BorderThickness="0" Padding="0" Margin="8,0,8,4" Cursor="Hand">
                        <Border CornerRadius="8" Padding="16,12"
                                Background="{Binding CurrentView, Converter={StaticResource StringEqualsToBrushConverter}, ConverterParameter=AiScan}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🤖" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="AI Smart Scan" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"
                                           Foreground="{Binding CurrentView, Converter={StaticResource StringEqualsToForegroundConverter}, ConverterParameter=AiScan}"/>
                            </StackPanel>
                        </Border>
                    </Button>

                    <!-- Phase 6: Settings (disabled) -->
                    <Border Background="Transparent" CornerRadius="8" Padding="16,12" Margin="8,0,8,4" Opacity="0.4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Settings" Foreground="#6B7290" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- AI Status Badge -->
                    <Border CornerRadius="6" Padding="10,6" Margin="20,20,20,0" HorizontalAlignment="Left"
                            Background="{Binding AiStatusColor, Converter={StaticResource StringToColorBrushConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🤖" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AiStatus}" Foreground="White" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Version badge at bottom of sidebar -->
                    <TextBlock Text="v0.5 — Phase 5" FontSize="10" Foreground="#4A4A6A"
                               Margin="24,16,0,0" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- ── MAIN PANEL ── -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="0">
                <Grid Margin="32,28,32,16">
                    <!-- CONNECT VIEW -->
                    <StackPanel Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisConverter}, ConverterParameter=Connect}">

                        <!-- Section Title -->
                        <TextBlock Text="Outlook Connection" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                        <TextBlock Text="Connect to Outlook Desktop and select an account to manage."
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20"/>

                    <!-- ── CONNECTION CARD ── -->
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Connection" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Button Content="🔌  Connect to Outlook"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ConnectCommand}"
                                        IsEnabled="{Binding IsConnecting, Converter={StaticResource InverseBoolConverter}}"
                                        Margin="0,0,10,0"/>

                                <Button Content="Disconnect"
                                        Style="{StaticResource DangerButton}"
                                        Command="{Binding DisconnectCommand}"
                                        Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>

                            <!-- Loading indicator -->
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                                        Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="⏳" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="Connecting to Outlook... please wait"
                                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Error display -->
                            <Border Background="#FFEBEE" CornerRadius="6" Padding="14,12" Margin="0,12,0,0"
                                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="⚠️" FontSize="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding ErrorCode}" FontWeight="Bold"
                                                   Foreground="{StaticResource ErrorBrush}" FontSize="13"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap"
                                               Foreground="#C62828" FontSize="13"/>
                                    <Button Content="🔄  Retry" Style="{StaticResource SecondaryButton}"
                                            Command="{Binding RetryCommand}" Margin="0,10,0,0"
                                            HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── ACCOUNTS LIST ── -->
                    <Border Style="{StaticResource CardBorder}"
                            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <TextBlock Text="Email Accounts" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="10,2,0,0">
                                    <Run Text="("/>
                                    <Run Text="{Binding Accounts.Count, Mode=OneWay}"/>
                                    <Run Text=" found)"/>
                                </TextBlock>
                            </StackPanel>

                            <ListBox ItemsSource="{Binding Accounts}"
                                     SelectedItem="{Binding SelectedAccount}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Padding="0">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="itemBorder"
                                                            Background="#F8F9FC"
                                                            CornerRadius="10"
                                                            Padding="16,14"
                                                            Margin="0,0,0,8"
                                                            BorderThickness="2"
                                                            BorderBrush="#E5E7EB"
                                                            Cursor="Hand">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="itemBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                            <Setter TargetName="itemBorder" Property="Background" Value="#EDE7F6"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="itemBorder" Property="Background" Value="#F0EDFF"/>
                                                            <Setter TargetName="itemBorder" Property="BorderBrush" Value="#C5CAE9"/>
                                                        </Trigger>
                                                        <MultiTrigger>
                                                            <MultiTrigger.Conditions>
                                                                <Condition Property="IsSelected" Value="True"/>
                                                                <Condition Property="IsMouseOver" Value="True"/>
                                                            </MultiTrigger.Conditions>
                                                            <Setter TargetName="itemBorder" Property="Background" Value="#D1C4E9"/>
                                                        </MultiTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Account icon -->
                                            <Border Grid.Column="0" Width="44" Height="44"
                                                    CornerRadius="22" Margin="0,0,14,0" VerticalAlignment="Center">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#6C63FF" Offset="0"/>
                                                        <GradientStop Color="#A78BFA" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="📬" FontSize="18"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Account details -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding EmailAddress}" FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <Border Background="#EDE7F6" CornerRadius="4" Padding="8,3" Margin="0,0,6,0">
                                                        <TextBlock FontSize="10" Foreground="#5A52D5" FontWeight="SemiBold">
                                                            <Run Text="{Binding ProviderHint, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </Border>
                                                    <Border Background="#E8F5E9" CornerRadius="4" Padding="8,3" Margin="0,0,6,0">
                                                        <TextBlock FontSize="10" Foreground="#2E7D32" FontWeight="SemiBold">
                                                            <Run Text="Inbox: "/>
                                                            <Run Text="{Binding InboxCount, Mode=OneWay, StringFormat=N0}"/>
                                                        </TextBlock>
                                                    </Border>
                                                    <Border Background="#FFF3E0" CornerRadius="4" Padding="8,3" Margin="0,0,6,0">
                                                        <TextBlock FontSize="10" Foreground="#E65100" FontWeight="SemiBold">
                                                            <Run Text="Deleted: "/>
                                                            <Run Text="{Binding DeletedItemsCount, Mode=OneWay, StringFormat=N0}"/>
                                                        </TextBlock>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Status badges -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <Border CornerRadius="4" Padding="8,4" HorizontalAlignment="Right">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#E8F5E9"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                                    <Setter Property="Background" Value="#FFEBEE"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="11">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="✅ Connected"/>
                                                                <Setter Property="Foreground" Value="#388E3C"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                                                        <Setter Property="Text" Value="❌ Offline"/>
                                                                        <Setter Property="Foreground" Value="#C62828"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <TextBlock FontSize="10" Margin="0,4,0,0" HorizontalAlignment="Right">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="No patterns yet"/>
                                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasPatternFile}" Value="True">
                                                                    <Setter Property="Text" Value="📋 Patterns loaded"/>
                                                                    <Setter Property="Foreground" Value="#1976D2"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                    <!-- ── SELECTED ACCOUNT DETAIL ── -->
                    <Border Style="{StaticResource CardBorder}"
                            Visibility="{Binding SelectedAccount, Converter={StaticResource NullToCollapsedConverter}}">
                        <StackPanel>
                            <TextBlock Text="Active Account" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Display Name" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedAccount.DisplayName}"
                                           FontSize="13" Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Email Address" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedAccount.EmailAddress}"
                                           FontSize="13" Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Store Name" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedAccount.StoreName}"
                                           FontSize="13" Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Provider" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedAccount.ProviderHint}"
                                           FontSize="13" Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Account Key" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedAccount.AccountKey}"
                                           FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Consolas"
                                           Margin="0,0,0,8"/>
                            </Grid>

                            <!-- Next Steps -->
                            <Border Background="#EDE7F6" CornerRadius="6" Padding="14,12" Margin="0,14,0,0">
                                <StackPanel>
                                    <TextBlock Text="✅ Account selected — ready for next phase" FontWeight="SemiBold"
                                               Foreground="#5A52D5" FontSize="13"/>
                                    <TextBlock Text="Phase 2 will add 'Analyze Patterns' to scan deleted and inbox emails."
                                               Foreground="#6C63FF" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── WELCOME CARD (before connection) ── -->
                    <Border Style="{StaticResource CardBorder}"
                            Visibility="{Binding IsConnected, Converter={StaticResource InverseBoolToVisConverter}}">
                        <StackPanel Visibility="{Binding HasError, Converter={StaticResource InverseBoolToVisConverter}}">
                            <TextBlock Text="Getting Started" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,14"/>

                            <StackPanel Margin="0,0,0,8">
                                <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12">
                                    <Run FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">Step 1:</Run>
                                    <Run> Make sure Outlook Desktop is running with your accounts configured.</Run>
                                </TextBlock>
                                <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12">
                                    <Run FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">Step 2:</Run>
                                    <Run> Click "Connect to Outlook" above to discover your accounts.</Run>
                                </TextBlock>
                                <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12">
                                    <Run FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">Step 3:</Run>
                                    <Run> Select the account you want to manage.</Run>
                                </TextBlock>
                            </StackPanel>

                            <Separator Margin="0,4,0,14"/>

                            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap">
                                <Run FontWeight="SemiBold">Safety note:</Run>
                                <Run> EmailManage never permanently deletes emails. It only moves messages to triage folders for your review.</Run>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    </StackPanel>

                    <!-- ANALYZE VIEW -->
                    <StackPanel Visibility="{Binding CurrentView, Converter={StaticResource StringEqualsToVisConverter}, ConverterParameter=Analyze}">
                        <TextBlock Text="Analyze Patterns" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                        <TextBlock Text="Scan your inbox and deleted items to build an initial cleanup model."
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20"/>

                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Pattern Bootstrap" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                                <TextBlock Text="{Binding SelectedAccount.EmailAddress, StringFormat='Account: {0}'}" 
                                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,16"/>

                                <Button Content="▶️  Run Analysis (Last 12 Months)"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding AnalyzePatternsCommand}"
                                        IsEnabled="{Binding IsAnalyzing, Converter={StaticResource InverseBoolConverter}}"
                                        HorizontalAlignment="Left" Margin="0,0,0,16"/>

                                <StackPanel Visibility="{Binding IsAnalyzing, Converter={StaticResource BoolToVis}}" Margin="0,0,0,16">
                                    <TextBlock Text="⏳" FontSize="16" Margin="0,0,8,0" HorizontalAlignment="Left"/>
                                    <TextBlock Text="{Binding AnalysisProgress}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>

                                <Border Background="#E8F5E9" CornerRadius="8" Padding="20,18" 
                                        Visibility="{Binding LastAnalysisResult, Converter={StaticResource NullToCollapsedConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="✅ Analysis Complete" FontWeight="Bold" Foreground="#1B5E20" FontSize="17" Margin="0,0,0,14"/>
                                        <TextBlock Text="{Binding LastAnalysisResult.DeletedCount, StringFormat='Deleted items scanned: {0}'}" FontSize="15" Foreground="#212121" Margin="0,0,0,6"/>
                                        <TextBlock Text="{Binding LastAnalysisResult.KeptCount, StringFormat='Kept inbox items scanned: {0}'}" FontSize="15" Foreground="#212121" Margin="0,0,0,6"/>
                                        <TextBlock Text="{Binding LastAnalysisResult.Patterns.Count, StringFormat='Patterns generated: {0}'}" FontSize="15" FontWeight="Bold" Foreground="#212121" Margin="0,12,0,12"/>
                                        
                                        <TextBlock Text="Top Patterns:" FontWeight="Bold" FontSize="15" Foreground="#212121" Margin="0,0,0,6"/>
                                        <ItemsControl ItemsSource="{Binding LastAnalysisResult.Patterns}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="12,4,0,0">
                                                        <Border Background="#C8E6C9" CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                                            <TextBlock Text="{Binding Type}" FontSize="11" FontWeight="Bold" Foreground="#1B5E20"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding Value}" FontSize="14" FontWeight="SemiBold" Foreground="#333333" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- LEARN FROM DELETIONS CARD -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="🔄 Learn from Recent Deletions" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="Delete unwanted emails in Outlook, then click below to teach MailZen your preferences. Scans your Deleted Items from the last 7 days."
                                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                                <Button Content="🧠  Learn from My Deletions"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding LearnFromDeletionsCommand}"
                                        IsEnabled="{Binding IsLearning, Converter={StaticResource InverseBoolConverter}}"
                                        HorizontalAlignment="Left" Margin="0,0,0,16"/>

                                <!-- Learning progress -->
                                <StackPanel Visibility="{Binding IsLearning, Converter={StaticResource BoolToVis}}" Margin="0,0,0,16">
                                    <TextBlock Text="⏳" FontSize="16" Margin="0,0,8,0" HorizontalAlignment="Left"/>
                                    <TextBlock Text="{Binding LearnProgress}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>

                                <!-- Learn results -->
                                <Border CornerRadius="8" Padding="20,18" 
                                        Visibility="{Binding LastLearnResult, Converter={StaticResource NullToCollapsedConverter}}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#E8F5E9" Offset="0"/>
                                            <GradientStop Color="#EDE7F6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel>
                                        <TextBlock Text="✅ Learning Complete" FontWeight="Bold" Foreground="#2E7D32" FontSize="17" Margin="0,0,0,12"/>
