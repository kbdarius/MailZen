<Window x:Class="EmailManage.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:EmailManage.ViewModels"
        mc:Ignorable="d"
        Title="{Binding AppTitle}"
        Height="720" Width="860" MinHeight="600" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        Loaded="Window_Loaded"
        Closed="Window_Closed">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header bar -->
            <RowDefinition Height="*"/>      <!-- Content -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER BAR ═══ -->
        <Border Grid.Row="0" Padding="24,14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Color="{StaticResource HeaderGradientStartColor}" Offset="0"/>
                    <GradientStop Color="{StaticResource HeaderGradientEndColor}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="✨" FontSize="24" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="MailZen" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="Smart Email Cleanup" FontSize="12" Foreground="#D1C4E9" VerticalAlignment="Center" Margin="14,3,0,0"
                               FontStyle="Italic" Opacity="0.85"/>
                </StackPanel>

                <!-- Connection Status Pill -->
                <Border Grid.Column="2" CornerRadius="14" Padding="12,5" VerticalAlignment="Center" Margin="0,0,12,0"
                        Background="{Binding ConnectionStatusColor, Converter={StaticResource StringToColorBrushConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Margin="0,0,6,0" VerticalAlignment="Center" Fill="White"/>
                        <TextBlock Text="{Binding ConnectionStatus}" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Gear Icon (Settings) -->
                <Button Grid.Column="3" Content="⚙️" FontSize="20" Background="Transparent" BorderThickness="0"
                        Foreground="White" Cursor="Hand" Padding="8,4" ToolTip="Settings"
                        Command="{Binding ToggleSettingsCommand}"/>
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0">
            <Grid Margin="40,28,40,16">

                <!-- ═══ SETTINGS OVERLAY (shown when gear is clicked) ═══ -->
                <Border Visibility="{Binding ShowSettings, Converter={StaticResource BoolToVis}}"
                        Background="White" CornerRadius="12" Padding="28" Margin="0,0,0,16"
                        BorderBrush="#E5E7EB" BorderThickness="1" Panel.ZIndex="10">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.08" Color="Black"/>
                    </Border.Effect>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="⚙️ Settings" FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Button Content="✕" FontSize="16" Background="Transparent" BorderThickness="0"
                                    Foreground="{StaticResource TextSecondaryBrush}" Cursor="Hand" Margin="20,0,0,0"
                                    Command="{Binding ToggleSettingsCommand}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- ═══ AI Model Section ═══ -->
                        <TextBlock Text="🤖 AI Engine (Ollama)" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border CornerRadius="4" Padding="8,4" Margin="0,0,8,0"
                                    Background="{Binding AiStatusColor, Converter={StaticResource StringToColorBrushConverter}}">
                                <TextBlock Text="{Binding AiStatus}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="{Binding AiModelName}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AiModelSize, StringFormat=' ({0})'}" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                       Visibility="{Binding AiModelSize, Converter={StaticResource NullToCollapsedConverter}}"/>
                        </StackPanel>

                        <TextBlock Text="{Binding AiOllamaVersion, StringFormat='Ollama v{0}'}" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"
                                   Visibility="{Binding AiOllamaVersion, Converter={StaticResource NullToCollapsedConverter}}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Button Content="🔄 Check for Updates" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding CheckAiUpdatesCommand}" Margin="0,0,10,0"
                                    Visibility="{Binding IsAiReady, Converter={StaticResource BoolToVis}}"/>
                            <!-- Install Ollama button (shown only when not installed) -->
                            <Button Content="📥 Install Ollama + Model" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding InstallOllamaCommand}" Margin="0,0,10,0"
                                    Visibility="{Binding IsAiReady, Converter={StaticResource InverseBoolToVisConverter}}"
                                    IsEnabled="{Binding IsInstallingOllama, Converter={StaticResource InverseBoolConverter}}"/>
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding IsInstallingOllama, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="⏳" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                           MaxWidth="300" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Separator -->
                        <Border Height="1" Background="#E5E7EB" Margin="0,0,0,16"/>

                        <!-- ═══ Connected Accounts ═══ -->
                        <TextBlock Text="📬 Connected Accounts" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding Accounts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="📬" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding EmailAddress}" FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding ProviderHint, StringFormat=' ({0})'}" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Separator -->
                        <Border Height="1" Background="#E5E7EB" Margin="0,16,0,16"/>

                        <!-- ═══ Learned Profile Stats ═══ -->
                        <TextBlock Text="🧠 Learned Profile" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding LearnedDomainCount}" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Domains" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding ProtectedSenderCount}" FontSize="20" FontWeight="Bold"
                                           Foreground="#2E7D32" HorizontalAlignment="Center"/>
                                <TextBlock Text="Protected" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{Binding RuledSenderCount}" FontSize="20" FontWeight="Bold"
                                           Foreground="#E65100" HorizontalAlignment="Center"/>
                                <TextBlock Text="Rules" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="{Binding ProfileLastLearnedAt, TargetNullValue='Never'}" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                                <TextBlock Text="Last Learned" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Button Content="🗑 Reset Profile" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding ResetProfileCommand}" Margin="0,0,10,0"
                                    ToolTip="Clears all learned patterns, protected senders, and rule tracking. Does NOT delete Outlook rules."/>
                        </StackPanel>

                        <!-- Separator -->
                        <Border Height="1" Background="#E5E7EB" Margin="0,0,0,16"/>

                        <!-- ═══ Diagnostics ═══ -->
                        <TextBlock Text="🔍 Diagnostics" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Rolling logs (14 days) stored in %LOCALAPPDATA%\EmailManage\" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <Button Content="📂 Open Log Folder" Style="{StaticResource SecondaryButton}"
                                Command="{Binding ExportLogsCommand}" HorizontalAlignment="Left"
                                ToolTip="Opens the log folder in File Explorer for sharing or review."/>
                    </StackPanel>
                </Border>

                <!-- ═══ WORKFLOW PIPELINE ═══ -->
                <StackPanel Visibility="{Binding ShowSettings, Converter={StaticResource InverseBoolToVisConverter}}">

                    <!-- ── STEP INDICATOR (horizontal progress bar) ── -->
                    <Border Style="{StaticResource CardBorder}" Padding="24,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Step 1: Connect -->
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <Border Width="38" Height="38" CornerRadius="19" HorizontalAlignment="Center"
                                        Background="{Binding Step1Color, Converter={StaticResource StringToColorBrushConverter}}">
                                    <TextBlock Text="1" FontSize="16" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Connect" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Connector line -->
                            <Border Grid.Column="1" Height="3" Width="40" VerticalAlignment="Center" Margin="0,0,0,16"
                                    Background="{Binding Step2Color, Converter={StaticResource StringToColorBrushConverter}}" CornerRadius="2"/>

                            <!-- Step 2: Learn -->
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <Border Width="38" Height="38" CornerRadius="19" HorizontalAlignment="Center"
                                        Background="{Binding Step2Color, Converter={StaticResource StringToColorBrushConverter}}">
                                    <TextBlock Text="2" FontSize="16" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Learn" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>

                            <Border Grid.Column="3" Height="3" Width="40" VerticalAlignment="Center" Margin="0,0,0,16"
                                    Background="{Binding Step3Color, Converter={StaticResource StringToColorBrushConverter}}" CornerRadius="2"/>

                            <!-- Step 3: Triage -->
                            <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                <Border Width="38" Height="38" CornerRadius="19" HorizontalAlignment="Center"
                                        Background="{Binding Step3Color, Converter={StaticResource StringToColorBrushConverter}}">
                                    <TextBlock Text="3" FontSize="16" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Triage" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>

                            <Border Grid.Column="5" Height="3" Width="40" VerticalAlignment="Center" Margin="0,0,0,16"
                                    Background="{Binding Step4Color, Converter={StaticResource StringToColorBrushConverter}}" CornerRadius="2"/>

                            <!-- Step 4: Review -->
                            <StackPanel Grid.Column="6" HorizontalAlignment="Center">
                                <Border Width="38" Height="38" CornerRadius="19" HorizontalAlignment="Center"
                                        Background="{Binding Step4Color, Converter={StaticResource StringToColorBrushConverter}}">
                                    <TextBlock Text="4" FontSize="16" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Review" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>

                            <Border Grid.Column="7" Height="3" Width="40" VerticalAlignment="Center" Margin="0,0,0,16"
                                    Background="{Binding Step5Color, Converter={StaticResource StringToColorBrushConverter}}" CornerRadius="2"/>

                            <!-- Step 5: Automate -->
                            <StackPanel Grid.Column="8" HorizontalAlignment="Center">
                                <Border Width="38" Height="38" CornerRadius="19" HorizontalAlignment="Center"
                                        Background="{Binding Step5Color, Converter={StaticResource StringToColorBrushConverter}}">
                                    <TextBlock Text="5" FontSize="16" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Automate" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ── STEP 1: CONNECTING (auto, no button) ── -->
                    <Border Style="{StaticResource CardBorder}"
                            Visibility="{Binding CurrentStep, Converter={StaticResource StringEqualsToVisConverter}, ConverterParameter=Connect}">
                        <StackPanel>
                            <TextBlock Text="🔌 Connecting to Outlook..." FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock Text="MailZen is connecting to Outlook Desktop and setting up the AI engine."
                                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16" TextWrapping="Wrap"/>

                            <!-- Progress -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                        Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="⏳" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Error -->
                            <Border Background="#FFEBEE" CornerRadius="6" Padding="14,12" Margin="0,8,0,0"
                                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="⚠️" FontSize="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap"
                                                   Foreground="#C62828" FontSize="13"/>
                                    </StackPanel>
                                    <Button Content="🔄  Retry" Style="{StaticResource SecondaryButton}"
                                            Command="{Binding RetryConnectCommand}" Margin="0,10,0,0"
                                            HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── STEP 2: LEARNING (AI scans deleted items) ── -->
                    <Border Style="{StaticResource CardBorder}"
                            Visibility="{Binding CurrentStep, Converter={StaticResource StringEqualsToVisConverter}, ConverterParameter=Learn}">
                        <StackPanel>
                            <TextBlock Text="🧠 Learning Your Habits" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16">
                                <Run Text="MailZen uses a local AI to learn what you delete and identify junk in your inbox."/>
                            </TextBlock>

                            <!-- ── AI NOT READY: Setup prompt (shown for new users) ── -->
                            <Border Background="#FFF3E0" CornerRadius="8" Padding="18,14" Margin="0,0,0,16"
                                    Visibility="{Binding IsAiReady, Converter={StaticResource InverseBoolToVisConverter}}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="🤖" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="AI Engine Setup Required" FontSize="14" FontWeight="Bold"
                                                   Foreground="#E65100" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#424242" Margin="0,0,0,12">
                                        <Run Text="MailZen needs "/>
                                        <Run Text="Ollama" FontWeight="Bold"/>
                                        <Run Text=" (a free, private AI engine) to analyse your email. Everything runs locally on your computer — no data is sent anywhere."/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#757575" Margin="0,0,0,12">
                                        <Run Text="This is a one-time setup. It will download ~2.5 GB for the AI model. You'll need an internet connection."/>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="📥  Install Ollama + AI Model" Style="{StaticResource PrimaryButton}"
                                                Command="{Binding InstallOllamaCommand}" Margin="0,0,12,0"
                                                IsEnabled="{Binding IsInstallingOllama, Converter={StaticResource InverseBoolConverter}}"/>
                                        <StackPanel Orientation="Horizontal"
                                                    Visibility="{Binding IsInstallingOllama, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="⏳" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                                                       Foreground="#E65100" VerticalAlignment="Center"
                                                       MaxWidth="400" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Account selector for multi-account -->
                            <StackPanel Visibility="{Binding ShowAccountPicker, Converter={StaticResource BoolToVis}}" Margin="0,0,0,16">
                                <TextBlock Text="Select an account to start with:" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <ListBox ItemsSource="{Binding Accounts}" SelectedItem="{Binding SelectedAccount}"
                                         BorderThickness="0" Background="Transparent" Padding="0">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="itemBorder" Background="#F8F9FC" CornerRadius="8"
                                                                Padding="14,10" Margin="0,0,0,6" BorderThickness="2"
                                                                BorderBrush="#E5E7EB" Cursor="Hand">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="itemBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                                <Setter TargetName="itemBorder" Property="Background" Value="#EDE7F6"/>
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="itemBorder" Property="Background" Value="#F0EDFF"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📬" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding EmailAddress}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                <Border Background="#EDE7F6" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ProviderHint}" FontSize="10" Foreground="#5A52D5" FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>

                            <Button Content="▶️  Start Learning" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding StartLearningCommand}" HorizontalAlignment="Left" Margin="0,0,0,16"
                                    Visibility="{Binding ShowStartLearning, Converter={StaticResource BoolToVis}}"
                                    IsEnabled="{Binding IsAiReady}"/>

                            <!-- Progress -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                        Visibility="{Binding IsLearning, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="⏳" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Stop button (visible while running) -->
                            <Button Content="⏹  Stop" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding StopOperationCommand}" HorizontalAlignment="Left" Margin="0,4,0,8"
                                    Visibility="{Binding CanStop, Converter={StaticResource BoolToVis}}"/>

                            <!-- Stopped state: Resume / Skip to Triage -->
                            <StackPanel Visibility="{Binding WasStopped, Converter={StaticResource BoolToVis}}"
                                        Margin="0,4,0,0">
                                <TextBlock Text="{Binding StatusMessage}" FontSize="13" Margin="0,0,0,12"
                                           Foreground="#E65100" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="▶️  Resume" Style="{StaticResource PrimaryButton}"
                                            Command="{Binding ResumeCommand}" Margin="0,0,12,0"/>
                                    <Button Content="⏩  Skip to Triage" Style="{StaticResource SecondaryButton}"
                                            Command="{Binding SkipToTriageCommand}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Error state -->
                            <Border Background="#FFEBEE" CornerRadius="6" Padding="14,12" Margin="0,8,0,0"
                                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="⚠️" FontSize="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap"
                                                   Foreground="#C62828" FontSize="13"/>
                                    </StackPanel>
                                    <Button Content="🔄  Retry" Style="{StaticResource SecondaryButton}"
                                            Command="{Binding StartLearningCommand}" Margin="0,10,0,0"
                                            HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── STEP 3: TRIAGE (AI scans inbox, moves to Review) ── -->
                    <Border Style="{StaticResource CardBorder}"
                            Visibility="{Binding CurrentStep, Converter={StaticResource StringEqualsToVisConverter}, ConverterParameter=Triage}">
                        <StackPanel>
                            <TextBlock Text="📧 Scanning Your Inbox" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16">
                                <Run Text="The AI is now scanning your inbox emails and identifying ones you probably don't want. Matches will be moved to the "/>
                                <Run Text="Review for Deletion" FontWeight="Bold"/>
                                <Run Text=" folder in Outlook."/>
                            </TextBlock>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                        Visibility="{Binding IsTriaging, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="⏳" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Stop button (visible while triage is running) -->
                            <Button Content="⏹  Stop" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding StopOperationCommand}" HorizontalAlignment="Left" Margin="0,4,0,8"
                                    Visibility="{Binding CanStop, Converter={StaticResource BoolToVis}}"/>

                            <!-- Stopped state: Resume / Skip to Review -->
                            <StackPanel Visibility="{Binding WasStopped, Converter={StaticResource BoolToVis}}"
                                        Margin="0,4,0,0">
                                <TextBlock Text="{Binding StatusMessage}" FontSize="13" Margin="0,0,0,12"
                                           Foreground="#E65100" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="▶️  Resume Triage" Style="{StaticResource PrimaryButton}"
                                            Command="{Binding ResumeCommand}" Margin="0,0,12,0"/>
                                    <Button Content="📂  Review What's Moved" Style="{StaticResource SecondaryButton}"
                                            Command="{Binding ContinueAfterReviewCommand}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Error state -->
                            <Border Background="#FFEBEE" CornerRadius="6" Padding="14,12" Margin="0,8,0,0"
                                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="⚠️" FontSize="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap"
                                                   Foreground="#C62828" FontSize="13"/>
                                    </StackPanel>
                                    <Button Content="🔄  Retry" Style="{StaticResource SecondaryButton}"
                                            Command="{Binding ResumeCommand}" Margin="0,10,0,0"
                                            HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── STEP 4: REVIEW (Handoff — user reviews in Outlook) ── -->
                    <Border Style="{StaticResource CardBorder}"
                            Visibility="{Binding CurrentStep, Converter={StaticResource StringEqualsToVisConverter}, ConverterParameter=Review}">
                        <StackPanel>
                            <TextBlock Text="📂 Review in Outlook" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>

                            <Border CornerRadius="8" Padding="20,16" Margin="0,0,0,16">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FFF8E1" Offset="0"/>
                                        <GradientStop Color="#FFF3E0" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <TextBlock FontSize="14" Foreground="#212121" TextWrapping="Wrap" Margin="0,0,0,8">
                                        <Run Text="I moved " FontWeight="SemiBold"/>
                                        <Run Text="{Binding ReviewCount, Mode=OneWay}" FontWeight="Bold" Foreground="#D32F2F"/>
                                        <Run Text=" emails to the " FontWeight="SemiBold"/>
                                        <Run Text="Review for Deletion" FontWeight="Bold" Foreground="#E65100"/>
                                        <Run Text=" folder." FontWeight="SemiBold"/>
                                    </TextBlock>
                                    <TextBlock FontSize="14" Foreground="#212121" TextWrapping="Wrap" Margin="0,0,0,6">
                                        <Run Text="1. Open Outlook → Review for Deletion"/>
                                    </TextBlock>
                                    <TextBlock FontSize="14" Foreground="#212121" TextWrapping="Wrap" Margin="0,0,0,6">
                                        <Run Text="2. Delete the emails you agree are junk"/>
                                    </TextBlock>
                                    <TextBlock FontSize="14" Foreground="#212121" TextWrapping="Wrap" Margin="0,0,0,6">
                                        <Run Text="3. Leave the ones you want to keep"/>
                                    </TextBlock>
                                    <TextBlock FontSize="14" Foreground="#212121" TextWrapping="Wrap">
                                        <Run Text="4. Come back here and click "/>
                                        <Run Text="Continue" FontWeight="Bold"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="✅  Continue" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ContinueAfterReviewCommand}" Margin="0,0,12,0"
                                        IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBoolConverter}}"/>
                                <StackPanel Orientation="Horizontal"
                                            Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="⏳" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── STEP 5: AUTOMATE (Results + Rules Created) ── -->
                    <Border Style="{StaticResource CardBorder}"
                            Visibility="{Binding CurrentStep, Converter={StaticResource StringEqualsToVisConverter}, ConverterParameter=Automate}">
                        <StackPanel>
                            <TextBlock Text="✅ Cleanup Complete!" FontSize="18" FontWeight="Bold"
                                       Foreground="#2E7D32" Margin="0,0,0,8"/>

                            <!-- Results Summary -->
                            <Border CornerRadius="8" Padding="20,16" Margin="0,0,0,16">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#E8F5E9" Offset="0"/>
                                        <GradientStop Color="#EDE7F6" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding DeletedCount, Mode=OneWay}" FontSize="28" FontWeight="Bold"
                                                       Foreground="#D32F2F" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Deleted (Junk)" FontSize="11" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding KeptCount, Mode=OneWay}" FontSize="28" FontWeight="Bold"
                                                       Foreground="#2E7D32" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Kept → Inbox" FontSize="11" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding RulesCreatedCount, Mode=OneWay}" FontSize="28" FontWeight="Bold"
                                                       Foreground="#6C63FF" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Rules Created" FontSize="11" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="{Binding StatusMessage}" FontSize="13"
                                               Foreground="#555" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                </StackPanel>
                            </Border>

                            <Button Content="🔄  Run Again" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding RunAgainCommand}" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="2" Padding="20,8">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Color="#1E1E2E" Offset="0"/>
                    <GradientStop Color="#2D2D44" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusBarText}"
                           FontSize="11" Foreground="#A0A3BD" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="✨ MailZen v1.0"
                           FontSize="10" Foreground="#6B7290" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
